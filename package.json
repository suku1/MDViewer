{
  "name": "mdviewer",
  "version": "0.1.0",
  "description": "Markdownファイルを閲覧可能なビューア",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "tsc && electron .",
    "package": "tsc && electron-builder"
  },
  "keywords": ["markdown", "viewer", "electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.mdviewer.app",
    "productName": "MDViewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "build/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "sign": null,
      "publish": {
        "provider": "github",
        "releaseType": "release"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MDViewer",
      "include": "build/installer.nsh"
    },
    "forceCodeSigning": false,
    "buildDependenciesFromSource": false,
    "removePackageScripts": true,
    "npmRebuild": false,
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility"
    }
  }
}
